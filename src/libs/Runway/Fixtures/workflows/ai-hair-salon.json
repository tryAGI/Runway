Type":"workflow_gemini_image","nodeProps":{"position":{"x":-591.2649872865966,"y":62.058352337122656}},"nodeInputs":{"name":{"type":"string","value":"workflow-gemini-image-task"},"num_images":{"type":"int","value":1},"exploreMode":{"type":"boolean","value":false},"text_prompt":{"type":"string","required":true},"aspect_ratio":{"type":"string","value":"16:9"},"reference_images":{"type":"image"}},"appNodeType":"gemini-image","nodeOutputs":{"image":{"type":"image"}},"nodeVersion":1},{"id":"6f2d3d31-518e-42b7-8ad1-644d23aab0ca","nodeType":"workflow-node","taskType":"workflow_gemini_api","nodeProps":{"position":{"x":-257.95042689144077,"y":23.484046708246254}},"nodeInputs":{"images":{"type":"image"},"prompt":{"type":"string"},"temperature":{"type":"number","value":1},"output_format":{"type":"string","value":"text"},"system_prompt":{"type":"string"},"max_output_tokens":{"type":"number","value":2000}},"appNodeType":"gemini","nodeOutputs":{"text":{"type":"string"}},"nodeVersion":1},{"id":"8331fc45-ba77-4c19-9f48-3fbad2aa6eaa","nodeType":"constant-node","nodeProps":{"position":{"x":-258.2194924640547,"y":-334.61695578620004}},"nodeOutputs":{"prompt":{"type":"string","label":"","value":"## Identity\nYou are a specialized hairstyle visualization assistant designed to help users explore different hair transformations while maintaining the integrity of the original subject. Your primary function is to generate four distinct, photorealistic hairstyle descriptions based on an input image, ensuring the subject's facial features, pose, and overall appearance remain unchanged while only the hair is modified.\n\n## Rules\n- Always generate exactly four distinct descriptions in JSON format with \"ID:1\" through \"ID:4\" as keys, regardless of whether the user specifies types or not.\n- Each description must be 2-3 sentences long and always start with \"The subject maintains the same pose as the input image, but now the hair style has changed.\"\n- When no specific hairstyle is requested, generate two gender-appropriate realistic styles, one featuring an interesting dyed color, and one wildcard style.\n- Never repeat the same hairstyle across the four outputs, ensuring each transformation is unique and distinct.\n- All descriptions must emphasize photorealistic rendering and explicitly state that the subject's face remains completely unaltered.\n- Never modify, alter, or change any facial features, skin tone, expression, or identifying characteristics of the original subject.\n\n## Example\nUser prompt: \"Show me different hairstyles for this person.\"\n\nYour response:\n```json\n{\n  \"ID:1\": \"The subject maintains the same pose as the input image, but now the hair style has changed. The person now has a sleek, shoulder-length bob with subtle layers that frame the face naturally, styled with a smooth, glossy finish in their natural hair color. The cut is professional and timeless, with a slight side part that adds sophistication.\",\n  \n  \"ID:2\": \"The subject maintains the same pose as the input image, but now the hair style has changed. The person now has a textured, medium-length cut with soft waves and natural movement, styled in a relaxed, effortless manner. The overall look is casual yet polished, maintaining the original hair color with added depth and dimension.\",\n  \n  \"ID:3\": \"The subject maintains the same pose as the input image, but now the hair style has changed. The person now has vibrant, electric blue hair styled in a modern asymmetrical cut with one side slightly longer than the other. The color is bold and evenly saturated, creating a striking contrast while maintaining the same photorealistic texture and shine.\",\n  \n  \"ID:4\": \"The subject maintains the same pose as the input image, but now the hair style has changed. The person now has an elaborate braided crown with intricate cornrows that spiral into a complex geometric pattern, adorned with subtle metallic thread woven throughout. The style is detailed and artistic, showcasing technical precision while keeping the natural hair texture visible.\"\n}\n```\n\n## DO NOT IGNORE THIS RULE\n- The subject's face, facial features, expression, skin tone, and pose must remain absolutely identical to the input image in every single output—only the hairstyle changes.","exposedToApp":true}},"constantNodeType":"prompt"},{"id":"486637ca-469c-4d31-92a2-40e3eccc7f3d","nodeType":"workflow-node","taskType":"workflow_gemini_image","nodeProps":{"position":{"x":865.3623646718496,"y":-678.2391997941355}},"nodeInputs":{"name":{"type":"string","value":"workflow-gemini-image-3-pro-task"},"model":{"type":"string","value":"gemini-3-pro-image-preview"},"image_size":{"type":"string","value":"1K"},"num_images":{"type":"int","value":1},"exploreMode":{"type":"boolean","value":false},"text_prompt":{"type":"string","required":true},"aspect_ratio":{"type":"string"},"reference_images":{"type":"image"}},"appNodeType":"gemini-image-3-pro","nodeOutputs":{"image":{"type":"image","label":"","exposedToApp":true}},"nodeVersion":1},{"id":"57435156-1c38-4c6e-9ca2-56bc9a629412","nodeType":"workflow-node","taskType":"workflow_gemini_image","nodeProps":{"position":{"x":862.4948338595175,"y":-233.7719238826335}},"nodeInputs":{"name":{"type":"string","value":"workflow-gemini-image-3-pro-task"},"model":{"type":"string","value":"gemini-3-pro-image-preview"},"image_size":{"type":"string","value":"1K"},"num_images":{"type":"int","value":1},"exploreMode":{"type":"boolean","value":false},"text_prompt":{"type":"string","required":true},"aspect_ratio":{"type":"string"},"reference_images":{"type":"image"}},"appNodeType":"gemini-image-3-pro","nodeOutputs":{"image":{"type":"image","label":"","exposedToApp":true}},"nodeVersion":1},{"id":"7caeb48f-2678-4edc-bb4d-285cb63bae66","nodeType":"workflow-node","taskType":"workflow_gemini_image","nodeProps":{"position":{"x":873.9649571088465,"y":207.82782121653617}},"nodeInputs":{"name":{"type":"string","value":"workflow-gemini-image-3-pro-ta